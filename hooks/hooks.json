{
  "description": "Lightweight research-flavored hooks (no MCP, no Node bridge, plain shell).",
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$CODEX_PLUGIN_ROOT\"/hooks/pii-scrub.sh",
            "timeout": 5
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$CODEX_PLUGIN_ROOT\"/hooks/memory-load.sh",
            "timeout": 5
          },
          {
            "type": "command",
            "command": "bash \"$CODEX_PLUGIN_ROOT\"/hooks/setup-nudge.sh",
            "timeout": 5
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$CODEX_PLUGIN_ROOT\"/hooks/citation-warn.sh",
            "timeout": 5
          }
        ]
      }
    ]
  }
}
