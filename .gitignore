*.log
.DS_Store
__pycache__/
*.pyc

# Codex/OMX generated project state can contain unpublished research context,
# agent memory, local hook config, and PII patterns. Keep it local.
.codex/
.omx/

# Legacy local state from pre-Codex versions.
.claude/
.omc/

.env

# Local symlinks to external checkouts (per-user absolute paths)
/oh-my-codex-upstream
/oh-my-codex/
/oh-my-claudecode
/DoD-Agent

# Local design / working docs (orchestration roadmap drafts, RFCs, scratch).
# Specs migrate to wiki/ + skills/<name>/SKILL.md when implemented.
# Exception: example-state/ ships canonical state-schema JSON examples as
# tracked reference material (Phase 0 decision §7 + user ACK).
/develop/*
!/develop/example-state/
